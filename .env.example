# ═══════════════════════════════════════════════════════
#  Autonomous Trading System Configuration
# ═══════════════════════════════════════════════════════

# ── Portfolio ─────────────────────────────────────────
PORTFOLIO_TICKERS=TSLA,NVDA,MSFT,AMZN,AAPL
INITIAL_CASH=100000

# ── AWS Bedrock (Kimi K2.5 for FinMEM components) ────
AWS_ACCESS_KEY_ID=your-access-key-here
AWS_SECRET_ACCESS_KEY=your-secret-key-here
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=moonshotai.kimi-k2.5

# ── Google Gemini (for TradingAgents) ─────────────────
GOOGLE_API_KEY=your-gemini-key-here
TA_LLM_PROVIDER=google
TA_DEEP_LLM=gemini-2.5-pro
TA_QUICK_LLM=gemini-2.5-flash

# ── Alpaca Paper Trading ──────────────────────────────
ALPACA_API_KEY=your-alpaca-key-here
ALPACA_SECRET_KEY=your-alpaca-secret-here

# ── Scheduling ────────────────────────────────────────
CYCLE_INTERVAL=1800

# ── CVaR Optimizer ────────────────────────────────────
CVAR_CONFIDENCE=0.95
CVAR_MAX_WEIGHT=0.35
STOP_LOSS_PCT=0.05
CONCENTRATION_THRESHOLD=0.80

# ── Feature Flags ─────────────────────────────────────
ADAPTIVE_Q=true
ADAPTIVE_Q_MODE=hmm
LEARNED_IMPORTANCE=true
CROSS_TICKER=true

# ── Finnhub News (optional) ──────────────────────────
FINNHUB_API_KEY=your-finnhub-key-here
